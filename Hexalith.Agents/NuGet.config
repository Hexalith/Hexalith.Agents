<?xml version="1.0" encoding="utf-8"?>
<!--
  Supply-chain hardening baseline for new Hexalith modules (Hexalith.Memories precedent):
    * signatureValidationMode = require  — every restored package must carry a valid signature.
    * single nuget.org source with <clear/> — no implicit/secondary feeds.
    * package source mapping pins every package (pattern "*") to nuget.org so a future secondary
      feed cannot silently re-route a dependency.
    * trustedSigners pins the current nuget.org repository certificates. If nuget.org rotates those
      repository certificates, refresh this block from the official NuGet docs (or
      `nuget trusted-signers sync -Name nuget.org`) before the next restore.
-->
<configuration>
  <config>
    <add key="signatureValidationMode" value="require" />
  </config>

  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>

  <packageSourceMapping>
    <clear />
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>

  <trustedSigners>
    <clear />
    <repository name="nuget.org" serviceIndex="https://api.nuget.org/v3/index.json">
      <certificate fingerprint="0E5F38F57DC1BCC806D8494F4F90FBCEDD988B46760709CBEEC6F4219AA6157D"
        hashAlgorithm="SHA256" allowUntrustedRoot="false" />
      <certificate fingerprint="5A2901D6ADA3D18260B9C6DFE2133C95D74B9EEF6AE0E5DC334C8454D1477DF4"
        hashAlgorithm="SHA256" allowUntrustedRoot="false" />
      <certificate fingerprint="1F4B311D9ACC115C8DC8018B5A49E00FCE6DA8E2855F9F014CA6F34570BC482D"
        hashAlgorithm="SHA256" allowUntrustedRoot="false" />
    </repository>
  </trustedSigners>
</configuration>
