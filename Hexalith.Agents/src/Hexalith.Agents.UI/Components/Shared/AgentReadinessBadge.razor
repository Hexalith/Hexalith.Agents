@inject IStringLocalizer<AgentsResources> Localizer

@* agent-readiness-badge (AC2, AC5): color + icon + visible text — never color-only (UX-DR12). The accessible
   name is the same safe whole string and never carries ids/secrets/PII (AD-14). The badge distinguishes active
   lifecycle from callable readiness: Success is used only for the Callable state (UX-DR20). *@
<FluentBadge Appearance="BadgeAppearance.Tint"
             Color="@AgentReadiness.ColorFor(State)"
             IconStart="@StateIcon"
             role="status"
             aria-label="@Label"
             data-testid="@TestId">
    @Label
</FluentBadge>

@code {
    /// <summary>The canonical readiness state to render (compute via <see cref="AgentReadiness.MapState"/>).</summary>
    [Parameter]
    public AgentReadinessState State { get; set; } = AgentReadinessState.Unknown;

    /// <summary>Stable test id for the badge surface.</summary>
    [Parameter]
    public string TestId { get; set; } = "agent-readiness-badge";

    private string Label => Localizer[AgentReadiness.LabelKeyFor(State)];

    private Icon StateIcon => State switch
    {
        AgentReadinessState.Callable => FcFluentIcons.Checkmark16(),
        AgentReadinessState.Checking => FcFluentIcons.ArrowSync16(),
        AgentReadinessState.Disabled => FcFluentIcons.SubtractCircle16(),
        AgentReadinessState.MissingPartyIdentity => FcFluentIcons.Warning16(),
        AgentReadinessState.ProviderUnavailable => FcFluentIcons.Warning16(),
        AgentReadinessState.InvalidConfiguration => FcFluentIcons.Warning16(),
        AgentReadinessState.Unresolved => FcFluentIcons.QuestionCircle16(),
        _ => FcFluentIcons.QuestionCircle16(),
    };
}
